# ───────────────────────────────────────────────────
# SSEXCH247 Risk Analysis Poller & WhatsApp Alerts
# ───────────────────────────────────────────────────

# ── Portal Auth ────────────────────────────────────
PORTAL_LOGIN_URL=https://newadmin.ssexch247.net/login
PORTAL_BASE_URL=https://newadmin.ssexch247.net
USERNAME=your_username
PASSWORD=your_password

# ── API Endpoints ──────────────────────────────────
LOGIN_API_BASE=https://slbo.ssexch247.net/api
API_BASE=https://newadmin.ssexch247.net/api
# Risk Analysis: MSACurrentWorkingMarketList
# Deposit: MSAClientPaymentRequestList
# Withdraw: MSAClientWithdrawRequestList
# Dashboard: GetDashBoard
POLL_ENDPOINT=MSACurrentWorkingMarketList

# ── Polling interval (seconds) ─────────────────────
POLL_INTERVAL_SECONDS=30

# ── Risk Thresholds ────────────────────────────────
# Only alert if absolute liability >= this value (0 = all)
MIN_LIABILITY_THRESHOLD=0

# ── WhatsApp Notification Gateway ──────────────────
# Twilio:    https://api.twilio.com/.../Messages.json
# WATI:      https://live-server-XXX.wati.io/api/v1/sendTemplateMessage
# Whapi:     https://gate.whapi.cloud/messages/text
# CallMeBot: https://api.callmebot.com/whatsapp.php
# Custom:    Any HTTP POST accepting {to, message}
WEBHOOK_URL=

# ── WhatsApp Recipients ────────────────────────────
# Comma-separated numbers with country code, no +/spaces
# Example: 919876543210,919876543211,919876543212,919876543213
WHATSAPP_RECIPIENTS=

# ── reCAPTCHA ──────────────────────────────────────
RECAPTCHA_SITE_KEY=6LfaGQQeAAAAAHGQ_EEv9PWEu8pQE_suL2WUSL7h
RECAPTCHA_MANUAL_SOLVE=false

# ── Login Selectors ────────────────────────────────
LOGIN_USERNAME_SELECTOR=input[type="text"][placeholder="Enter your username"]
LOGIN_PASSWORD_SELECTOR=input#password-input
LOGIN_SUBMIT_SELECTOR=button:has-text("Log in")

# ── Database ───────────────────────────────────────
DB_PATH=./data/processed_trades.db
AUTH_STATE_PATH=./data/auth_state.json

# ── Playwright / Deployment ────────────────────────
HEADLESS=true
BROWSER_TIMEOUT_MS=30000

# ── Health Check (0 = disabled) ────────────────────
HEALTH_CHECK_PORT=0
